private fun takePhoto() {
    val imageCapture = imageCapture ?: return
    val photoFile = File(externalCacheDir, "${System.currentTimeMillis()}.jpg")
    val outputOptions = ImageCapture.OutputFileOptions.Builder(photoFile).build()

    imageCapture.takePicture(outputOptions, ContextCompat.getMainExecutor(this), 
        object : ImageCapture.OnImageSavedCallback {
            override fun onImageSaved(output: ImageCapture.OutputFileResults) {
                val savedUri = Uri.fromFile(photoFile).toString()
                // Save this 'savedUri' to your RoomDB via ViewModel
                viewModel.saveExpense(currentAmount, currentCategory, savedUri)
            }
            override fun onError(exc: ImageCaptureException) { /* Handle Error */ }
        })
}